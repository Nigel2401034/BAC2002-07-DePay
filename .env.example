# DePay environment template
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Blockchain / wallets
# -----------------------------------------------------------------------------
# Deployer/admin private key (owner wallet for contract admin actions)
PRIVATE_KEY=

# Oracle wallet private key (used by oracle automation)
ORACLE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Deployed contract addresses (Hela testnet)
# -----------------------------------------------------------------------------
ESCROW_ADDRESS=
ORDER_TRACKING_ADDRESS=
DISPUTE_ADDRESS=

# -----------------------------------------------------------------------------
# App / backend
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://root:password@localhost:27018
NODE_ENV=development
SEED_LISTINGS_ON_START=true

# -----------------------------------------------------------------------------
# Pinata / IPFS
# -----------------------------------------------------------------------------
PINATA_JWT=

# -----------------------------------------------------------------------------
# Oracle daemon tuning (optional)
# -----------------------------------------------------------------------------
# BACKEND_URL=http://localhost:5000
# ORACLE_POLL_INTERVAL=15000
# ORACLE_SHIP_DELAY=30000
# ORACLE_DELIVER_DELAY=60000
