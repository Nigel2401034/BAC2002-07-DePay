# DePay environment template
# Copy this file to .env and fill in the values.
#
# WARNING:
# This file includes test-only keys and addresses for classroom/demo replication.
# This is NOT good security practice for real projects.
# Never reuse these values on mainnet/production.

# -----------------------------------------------------------------------------
# Blockchain / wallets
# -----------------------------------------------------------------------------
# Deployer/admin private key (owner wallet for contract admin actions)
# Format: 64 hex chars, no 0x prefix
PRIVATE_KEY=cfb4ec26ae2004b51951415a8a21b4913795a94a82b65c3f375bf09a3c26846c

# Oracle wallet private key (used by oracle automation)
ORACLE_PRIVATE_KEY=1b533c04926806c63f6c9afedefd3908cb2216dc160b1b928d3d481a36ffce9b

# RPC/network used by deployment scripts
RPC_URL=https://testnet-rpc.helachain.com
CHAIN_ID=0xa2d08

# -----------------------------------------------------------------------------
# Deployed contract addresses (Hela testnet)
# -----------------------------------------------------------------------------
# Format: 0x + 40 hex chars
ESCROW_ADDRESS=0xc4Ed2952c050Bd8330084f4C39155878B39939D4
ORDER_TRACKING_ADDRESS=0xC0efdbA6C116e5B3Ca4472E4F085a8fC542F1a82
DISPUTE_ADDRESS=0x6E29f3aBEa7bFed45560a1C270635e25705EB86e

# -----------------------------------------------------------------------------
# App / backend
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://root:password@localhost:27018
NODE_ENV=development
SEED_LISTINGS_ON_START=true

# -----------------------------------------------------------------------------
# Pinata / IPFS
# -----------------------------------------------------------------------------
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..vseOOQjRGTH6fmsfTplBmxMivh7Lw8z5s8RIO1WP6CU

